<div id="flash-messages-container">
  <% flash.each do |type, message| %>
    <% flash_class = case type.to_sym
        when :notice then "flash-success"
        when :alert  then "flash-danger"
        else "flash-info"
       end %>
    <div class="flash-message <%= flash_class %>">
      <%= message %>
    </div>
  <% end %>
</div>
<!-- Page-specific JavaScript -->



<script>
document.addEventListener("turbolinks:load", () => {

  // ── Quantity update ──────────────────────────────────────
  document.querySelectorAll(".quantity-input").forEach(input => {
    input.addEventListener("change", function () {
      const tr         = this.closest("tr");
      const lineItemId = tr?.dataset.lineItemId;
      if (!lineItemId) return;

      fetch(`/line_items/${lineItemId}`, {
        method: "PATCH",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
        },
        body: JSON.stringify({ line_item: { quantity: parseInt(this.value) } })
      })
      .then(r => r.json())
      .then(data => {
        if (!data.success) return;
        tr.querySelector("[data-cart-target='lineTotal']").innerText = data.line_item_total;
        document.getElementById("cart-count").innerText     = data.cart_count;
        document.getElementById("cart-subtotal").innerText  = data.cart_subtotal;
        document.getElementById("cart-total").innerText     = data.cart_total;
      });
    });
  });

  // ── Add to cart ───────────────────────────────────────────
  document.querySelectorAll(".add-to-cart-btn").forEach(btn => {
    btn.addEventListener("click", function () {
      fetch("/line_items", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
        },
        body: JSON.stringify({ product_variant_combination_id: this.dataset.variantId })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          document.getElementById("cart-count").innerText = data.cart_count;
          showToast("🛒 Added to cart", "success");
        }
      });
    });
  });

  // ── Wishlist toggle ───────────────────────────────────────
  // Mark already-wishlisted on page load
  (window.wishlistProductIds || []).forEach(id => {
    document.querySelectorAll(`.wishlist-btn[data-product-id="${id}"]`).forEach(btn => {
      btn.classList.add("active");
    });
  });

  document.querySelectorAll(".wishlist-btn").forEach(btn => {
    btn.addEventListener("click", function (e) {
      e.preventDefault();
      e.stopPropagation();

      const button = this;

      fetch("/wishlist_items", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
        },
        body: JSON.stringify({ product_id: this.dataset.productId })
      })
      .then(r => {
        if (r.status === 401) { window.location = "/login"; return null; }
        return r.json();
      })
      .then(data => {
        if (!data?.success) return;

        const countEl = document.getElementById("wishlist-count");
        if (countEl) countEl.innerText = data.wishlist_count;

        if (data.action === "added") {
          button.classList.add("active");
          showToast("❤️ Added to wishlist", "success");
        } else {
          button.classList.remove("active");
          showToast("Removed from wishlist", "info");
        }
      })
      .catch(err => console.error("Wishlist Error:", err));
    });
  });

  // ── Product card click navigation ────────────────────────
  document.querySelectorAll(".product__item").forEach(item => {
    item.addEventListener("click", function (e) {
      if (e.target.closest("a")) return;
      window.location = this.dataset.url;
    });
  });

  // ── Flash auto-dismiss ────────────────────────────────────
  document.querySelectorAll(".flash-message").forEach(msg => {
    setTimeout(() => msg.classList.add("show"), 100);
    setTimeout(() => {
      msg.classList.remove("show");
      setTimeout(() => msg.remove(), 500);
    }, 5000);
  });

});

// ── Toast helper ──────────────────────────────────────────
function showToast(message, type = "success") {
  const container = document.getElementById("flash-messages-container");
  if (!container) return;

  const div = document.createElement("div");
  div.className = `flash-message flash-${type}`;
  div.innerText  = message;
  container.appendChild(div);

  setTimeout(() => div.classList.add("show"), 50);
  setTimeout(() => {
    div.classList.remove("show");
    setTimeout(() => div.remove(), 500);
  }, 3000);
}
</script>
